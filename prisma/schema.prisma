generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Kline {
  id        String   @id @default(uuid())
  symbol    String
  interval  String
  openTime  DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float

  @@unique([symbol, interval, openTime])
  @@index([symbol, interval])
}
